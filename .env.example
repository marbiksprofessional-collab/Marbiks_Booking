# Copy to .env in this same directory before running
# `docker compose up --build -d` - see docs/HOSTINGER_DEPLOY.md.
# Compose loads .env automatically. Never commit the real .env.

PORT=3000

# Postgres credentials - used to create the database on first run AND by
# the backend to connect to it. Changing these after the first run does
# NOT change the already-created Postgres user/password; see
# docs/HOSTINGER_DEPLOY.md if you need to rotate them later.
DB_USERNAME=marbiks
DB_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_PASSWORD
DB_DATABASE=marbiks_erp

# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=8h

# Only read if you run `docker compose exec backend npm run seed`. Leave
# blank to use the script's built-in demo defaults (fine for a first local
# smoke test, NOT fine for real production - see docs/HOSTINGER_DEPLOY.md).
SEED_SUPER_ADMIN_EMAIL=
SEED_SUPER_ADMIN_PASSWORD=

# Leave blank to use the local-dev OTP fallback (code logged server-side,
# not delivered by SMS - fine for testing, not for real customers). Set to a
# real Fast2SMS API key (https://www.fast2sms.com/) to actually text
# customers their OTP; see docs/HOSTINGER_DEPLOY.md.
FAST2SMS_API_KEY=
