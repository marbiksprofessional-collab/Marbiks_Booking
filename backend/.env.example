PORT=3000
NODE_ENV=development

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=marbiks
DB_PASSWORD=marbiks
DB_DATABASE=marbiks_erp

JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=8h

# Leave blank to use the local-dev OTP fallback (code logged server-side and
# returned in the API response outside production). Set this to a real
# Fast2SMS API key (https://www.fast2sms.com/) to send real OTP SMS instead -
# once set, the code is never returned in the response, in any environment.
FAST2SMS_API_KEY=
